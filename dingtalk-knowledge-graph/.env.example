# DingTalk AppKey and AppSecret
# Get these from DingTalk Developer Console: https://open.dingtalk.com/
DINGTALK_APPKEY=your_appkey_here
DINGTALK_APPSECRET=your_appsecret_here

# Optional: Neo4j Configuration
# KNOWLEDGE_GRAPH_DB=neo4j
# NEO4J_URI=bolt://localhost:7687
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=your_password

# Optional: Vector Database Configuration
# VECTOR_DB=chromadb
# CHROMA_DB_PATH=./chroma_db
