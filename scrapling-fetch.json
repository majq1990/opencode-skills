{
    "name": "scrapling-fetch",
    "description": "使用 Scrapling 抓取网页内容，支持自适应选择器、反反爬虫、动态网页抓取",
    "command": "python C:\\Users\\majq1\\scrapling_simple.py {url} --format {format}",
    "arguments": {
        "url": {
            "type": "string",
            "description": "要抓取的 URL"
        },
        "format": {
            "type": "string",
            "enum": ["markdown", "text", "html"],
            "default": "markdown",
            "description": "输出格式"
        }
    },
    "examples": [
        "python C:\\Users\\majq1\\scrapling_simple.py https://example.com --format markdown",
        "python C:\\Users\\majq1\\scrapling_simple.py https://faq.egova.com.cn:7787/issues/487856 --format markdown"
    ]
}
